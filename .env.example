# Copy this file to `.env` and paste values from:
# Supabase Dashboard → Project Settings → API
#
# Project URL     → VITE_SUPABASE_URL
# anon public key → VITE_SUPABASE_PUBLISHABLE_KEY
# Reference ID    → VITE_SUPABASE_PROJECT_ID (same as subdomain: xxx.supabase.co)

VITE_SUPABASE_URL=https://oyxagifjstcrrvlounlw.supabase.co
# Anon (public) key from Supabase → Project Settings → API (same value as "publishable" / anon key)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im95eGFnaWZqc3RjcnJ2bG91bmx3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU4MzYyMDUsImV4cCI6MjA5MTQxMjIwNX0.bN7q-EPOSSfE0Dv8aZVXtcqlbkEqoR6YYmSmTvEbdvs
# Optional alias (client uses VITE_SUPABASE_ANON_KEY first)
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im95eGFnaWZqc3RjcnJ2bG91bmx3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU4MzYyMDUsImV4cCI6MjA5MTQxMjIwNX0.bN7q-EPOSSfE0Dv8aZVXtcqlbkEqoR6YYmSmTvEbdvs
VITE_SUPABASE_PROJECT_ID=oyxagifjstcrrvlounlw

# GIFs: GET {VITE_SUPABASE_URL}/functions/v1/exercise-gif?id={exerciseId}
# Supabase Dashboard → Edge Functions → exercise-gif → Secrets: set RAPIDAPI_KEY (same as RapidAPI ExerciseDB key).
# Deploy: npm run deploy:exercise-gif   (uses npx; no global supabase CLI required)
# config.toml: [functions.exercise-gif] verify_jwt = false so <img> requests work without JWT.

# Optional: public site origin for auth emails (password reset + signup confirmation redirect).
# Defaults to current browser origin in dev, or https://coachbase.health if unset.
# Add these URLs in Supabase → Authentication → URL Configuration → Redirect URLs:
#   {origin}/reset-password   {origin}/trainer-dashboard   {origin}/client-home
# Client app passes `siteOrigin` to send-invite-email; Edge fallback: PUBLIC_APP_URL secret (same origin as production).
#
# Resend (Edge Functions → Secrets — NOT VITE_*): required for invite emails to clients.
#   RESEND_API_KEY=re_xxxxxxxx
#   RESEND_FROM=CoachBase <noreply@your-verified-domain.com>
# Verify your domain in Resend (Domains), then use an address on that domain. Without RESEND_FROM,
# invite email uses noreply@coachbase.health (same as other Edge functions — domain must be verified in Resend).
# VITE_AUTH_SITE_ORIGIN=https://coachbase.health

# Tap Payments (Live): set in Supabase Dashboard → Edge Functions → Secrets (NOT in .env for the secret key).
# Required for create-tap-charge / payment redirect:
#   TAP_SECRET_KEY=sk_live_xxxxxxxx   (Live Secret Key from Tap dashboard)
# The Public Key (pk_live_...) is NOT used by the current server-side charge flow; optional only if you add client-side Tap.js:
#   VITE_TAP_PUBLIC_KEY=pk_live_xxxxxxxx

# Admin dashboard (Edge Function `admin-dashboard` — set via Supabase CLI/Dashboard secrets, not VITE_*).
# REQUIRED: Set ADMIN_DASHBOARD_SECRET in Edge Function secrets. The dashboard is disabled without it.
# supabase secrets set ADMIN_DASHBOARD_SECRET="<your-secure-password>" --project-ref <id>
