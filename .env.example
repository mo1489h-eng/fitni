# Copy this file to `.env` and paste values from:
# Supabase Dashboard → Project Settings → API
#
# Project URL     → VITE_SUPABASE_URL
# anon public key → VITE_SUPABASE_PUBLISHABLE_KEY
# Reference ID    → VITE_SUPABASE_PROJECT_ID (same as subdomain: xxx.supabase.co)

