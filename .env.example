VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im95eGFnaWZqc3RjcnJ2bG91bmx3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU4MzYyMDUsImV4cCI6MjA5MTQxMjIwNX0.bN7q-EPOSSfE0Dv8aZVXtcqlbkEqoR6YYmSmTvEbdvs
VITE_SUPABASE_PROJECT_ID=oyxagifjstcrrvlounlw

# GIFs: GET {VITE_SUPABASE_URL}/functions/v1/exercise-gif?id={exerciseId}
# Supabase Dashboard → Edge Functions → exercise-gif → Secrets: set RAPIDAPI_KEY (same as RapidAPI ExerciseDB key).
# Deploy: npm run deploy:exercise-gif   (uses npx; no global supabase CLI required)
# config.toml: [functions.exercise-gif] verify_jwt = false so <img> requests work without JWT.

# Optional: site origin for password-reset emails (defaults to https://coachbase.health).
# Add the same URL + /reset-password in Supabase → Authentication → URL Configuration → Redirect URLs.
# VITE_AUTH_SITE_ORIGIN=https://coachbase.health

# Admin dashboard (Edge Function `admin-dashboard` — set via Supabase CLI/Dashboard secrets, not VITE_*).
# Default login when ADMIN_DASHBOARD_SECRET is unset is exactly: fitni@2026@!Asa
# To pin the same value: supabase secrets set ADMIN_DASHBOARD_SECRET="fitni@2026@!Asa" --project-ref <id>
